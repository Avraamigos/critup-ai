{
  "functions": {
    "api/analyze.ts": { "maxDuration": 300 },
    "api/tts.ts":     { "maxDuration": 30  },
    "api/chat.ts":          { "maxDuration": 30  },
    "api/jury-script.ts":     { "maxDuration": 300 },
    "api/jury-script-shorten.ts": { "maxDuration": 30 },
    "api/paddle-webhook.ts":  { "maxDuration": 10  },
    "api/admin-stats.ts":     { "maxDuration": 15  },
    "api/admin-revenue.ts":   { "maxDuration": 15  },
    "api/admin-set-plan.ts":  { "maxDuration": 10  },
    "api/admin-actions.ts":   { "maxDuration": 15  },
    "api/admin-competitions.ts": { "maxDuration": 15 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "camera=(), geolocation=(), payment=*" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ]
}
